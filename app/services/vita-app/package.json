{
  "name": "vita-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@react-native-community/netinfo": "12.0.1",
    "expo": "~56.0.15",
    "expo-constants": "~56.0.20",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-manipulator": "~56.0.21",
    "expo-image-picker": "~56.0.20",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.20",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.21",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.6",
    "react": "19.2.3",
    "react-i18next": "^17.0.9",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "~29.7.0",
    "jest-expo": "^56.0.5",
    "openapi-typescript": "^7.13.0",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "api:gen": "openapi-typescript ../../../docs/contracts/vita-api-v0.yaml -o src/api/types.gen.ts",
    "api:check": "openapi-typescript ../../../docs/contracts/vita-api-v0.yaml -o .api-drift.tmp.ts && diff -q .api-drift.tmp.ts src/api/types.gen.ts && rm .api-drift.tmp.ts",
    "integration:smoke": "tsx scripts/integration-smoke.ts"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "resolver": "react-native-worklets/jest/resolver.js"
  }
}
