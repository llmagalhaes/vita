  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "api:gen": "openapi-typescript ../../../docs/contracts/vita-api-v0.yaml -o src/api/types.gen.ts",
